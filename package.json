{
  "name": "riverline-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI borrower recovery operating system",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @riverline/db migrate",
    "db:seed": "pnpm --filter @riverline/db seed",
    "worker": "pnpm --filter @riverline/workflows worker",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0"
  }
}
